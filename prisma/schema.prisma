generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  FACULTY
  STAFF
  DEPT_HEAD
  MAGS_OFFICER
  ADMIN
}

enum ResourceCategory {
  VENUE
  EQUIPMENT
  SERVICE
}

enum ReservationStatus {
  DRAFT
  PENDING_DEPT
  SEMI_APPROVED
  PENDING_MAGS
  APPROVED
  DECLINED
  CANCELLED
  COMPLETED
  REJECTED
}

enum ApprovalLevel {
  DEPT_HEAD
  MAGS_OFFICER
  DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GatePassStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  RETURNED
  EXPIRED
}

enum NotificationType {
  RESERVATION_UPDATE
  APPROVAL
  REJECTION
  SCHEDULE_REMINDER
  RETURN_REMINDER
  CONFLICT
  SYSTEM
}

enum TransferType {
  TRANSFER
  TURN_OVER
}

model Department {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  reservations Reservation[]
  transfers    TransferTurnover[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           UserRole  @default(STUDENT)
  departmentId   String?
  studentNumber  String?
  course         String?
  phone          String?
  emailVerified  DateTime?
  isActive       Boolean   @default(true)
  resetToken     String?
  resetTokenExp  DateTime?
  verifyToken    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  department        Department?      @relation(fields: [departmentId], references: [id])
  reservations      Reservation[]    @relation("RequestorReservations")
  gatePasses        GatePass[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  assignedApprovals ApprovalLog[]    @relation("ApproverLogs")
  savedEquipment    SavedEquipment[]

  @@index([departmentId])
  @@index([role])
}

model Resource {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  category          ResourceCategory
  description       String?
  capacity          Int?
  building          String?
  requiresSpecify   Boolean          @default(false)
  quantity          Int              @default(0)
  availableQuantity Int              @default(0)
  isActive          Boolean          @default(true)
  sortOrder         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  reservationVenues    ReservationVenue[]
  reservationEquipment ReservationEquipment[]
  reservationServices  ReservationService[]
  gatePassEquipment    GatePassEquipment[]
  transferItems        TransferItem[]
}

model Reservation {
  id                 String            @id @default(cuid())
  requestNumber      String            @unique
  userId             String
  departmentId       String
  campus             String
  eventTitle         String
  eventDescription   String?
  startDateTime      DateTime
  endDateTime        DateTime
  status             ReservationStatus @default(PENDING_DEPT)
  filingDate         DateTime          @default(now())
  itemsPersonnelNote String?
  customVenueSpecify String?
  conformeName       String?
  conformeDate       DateTime?
  conformeSigned     Boolean           @default(false)
  rejectionReason    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user       User                   @relation("RequestorReservations", fields: [userId], references: [id])
  department Department             @relation(fields: [departmentId], references: [id])
  venues     ReservationVenue[]
  equipment  ReservationEquipment[]
  services   ReservationService[]
  approvals  ApprovalLog[]
  gatePasses GatePass[]

  @@index([userId])
  @@index([departmentId])
  @@index([status])
  @@index([startDateTime, endDateTime])
}

model ReservationVenue {
  id            String  @id @default(cuid())
  reservationId String
  resourceId    String
  specifyText   String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])

  @@unique([reservationId, resourceId])
}

model ReservationEquipment {
  id            String @id @default(cuid())
  reservationId String
  resourceId    String
  quantity      Int    @default(1)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])

  @@unique([reservationId, resourceId])
}

model ReservationService {
  id            String  @id @default(cuid())
  reservationId String
  resourceId    String
  notes         String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])

  @@unique([reservationId, resourceId])
}

model GatePass {
  id                   String         @id @default(cuid())
  passNumber           String         @unique
  userId               String
  reservationId        String?
  dateFiled            DateTime       @default(now())
  requestorName        String
  course               String?
  studentNumber        String?
  equipmentType        String
  equipmentDescription String?
  brand                String?
  serialNumber         String?
  model                String?
  purpose              String
  entryDateTime        DateTime
  pullOutDateTime      DateTime
  returnDateTime       DateTime?
  status               GatePassStatus @default(PENDING)
  approvedByName       String?
  approvedAt           DateTime?
  qrCodeData           String?
  rejectionReason      String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  reservation Reservation?        @relation(fields: [reservationId], references: [id])
  equipment   GatePassEquipment[]
  approvals   ApprovalLog[]

  @@index([userId])
  @@index([status])
}

model GatePassEquipment {
  id         String  @id @default(cuid())
  gatePassId String
  resourceId String?
  customName String?
  quantity   Int     @default(1)

  gatePass GatePass  @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resourceId], references: [id])
}

model ApprovalLog {
  id            String         @id @default(cuid())
  entityType    String
  entityId      String
  approverId    String?
  level         ApprovalLevel
  status        ApprovalStatus @default(PENDING)
  remarks       String?
  signatureName String?
  actedAt       DateTime?
  reservationId String?
  gatePassId    String?

  approver    User?        @relation("ApproverLogs", fields: [approverId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  gatePass    GatePass?    @relation(fields: [gatePassId], references: [id])

  @@index([entityType, entityId])
}

model TransferTurnover {
  id           String       @id @default(cuid())
  formNumber   String       @unique
  departmentId String
  type         TransferType
  dateFiled    DateTime     @default(now())
  status       String       @default("PENDING")
  remarks      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  department Department     @relation(fields: [departmentId], references: [id])
  items      TransferItem[]
}

model TransferItem {
  id             String  @id @default(cuid())
  transferId     String
  resourceId     String?
  quantity       Int     @default(1)
  description    String
  brandSerial    String?
  propertyNumber String?
  remarks        String?

  transfer TransferTurnover @relation(fields: [transferId], references: [id], onDelete: Cascade)
  resource Resource?        @relation(fields: [resourceId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model SavedEquipment {
  id                   String   @id @default(cuid())
  userId               String
  label                String
  equipmentType        String
  equipmentDescription String?
  brand                String?
  serialNumber         String?
  model                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
